#!/usr/bin/env bash
# ============================================================
# claude-sandboxed-rebuild - Rebuild Claude CLI sandbox images
#
# Usage:
#   cld-rebuild          # Rebuild base (+ project image if in a project)
#   cld-rebuild --all    # Rebuild base + all discovered project images
# ============================================================

set -euo pipefail

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
WORKSPACE_ROOT="${CLD_WORKSPACE_ROOT:-$HOME/workspace}"

# ── Rebuild the base image ──────────────────────────────────
rebuild_base() {
  echo "[sandbox] Rebuilding base image..." >&2
  docker rmi claude-cli-sandbox 2>/dev/null || true
  docker build --no-cache -t claude-cli-sandbox -f "$SCRIPT_DIR/Dockerfile.claude" "$SCRIPT_DIR" >&2
  echo "[sandbox] Base image rebuilt" >&2
}

# ── Rebuild a project image ─────────────────────────────────
rebuild_project() {
  local project_root="$1"
  local project_name
  project_name=$(basename "$project_root")
  local image_name="claude-sandbox-${project_name}"

  echo "[sandbox] Rebuilding project image '$image_name'..." >&2
  docker rmi "$image_name" 2>/dev/null || true
  docker build --no-cache -t "$image_name" -f "$project_root/.cld/Dockerfile" "$project_root/.cld" >&2
  echo "[sandbox] Project image '$image_name' rebuilt" >&2
}

# ── Find project root from PWD ──────────────────────────────
find_project_root() {
  local dir="$PWD"
  while [[ "$dir" != "/" && "$dir" != "$HOME" ]]; do
    if [[ -f "$dir/.cld/Dockerfile" ]]; then
      echo "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  return 1
}

# ── Main ────────────────────────────────────────────────────
if [[ "${1:-}" == "--all" ]]; then
  # Rebuild base, then find and rebuild all project images
  rebuild_base

  echo "[sandbox] Scanning for project containers under $WORKSPACE_ROOT..." >&2
  found=0
  while IFS= read -r dockerfile; do
    project_dir="$(dirname "$(dirname "$dockerfile")")"
    rebuild_project "$project_dir"
    found=$((found + 1))
  done < <(find "$WORKSPACE_ROOT" -name "Dockerfile" -path "*/.cld/Dockerfile" 2>/dev/null)

  if [[ $found -eq 0 ]]; then
    echo "[sandbox] No project containers found" >&2
  fi
else
  # Rebuild base first (project images depend on it)
  rebuild_base

  # If inside a project, rebuild that project's image too
  if PROJECT_ROOT=$(find_project_root); then
    rebuild_project "$PROJECT_ROOT"
  fi
fi

echo "[sandbox] Rebuild complete" >&2
